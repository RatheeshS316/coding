 long           	nextLong()	           long l = scanner.nextLong();
 short          	nextShort()	            short s = scanner.nextShort();
 byte	            nextByte()	            byte b = scanner.nextByte();
 boolean	        nextBoolean()	       boolean flag = scanner.nextBoolean();
 String (word)	    next()	                String s = scanner.next();
